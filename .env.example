# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — your real keys will never be committed.
#
# Load it before running dndig-openai:
#     set -a; source .env; set +a
#     python3 tools/dndig-openai/dndig_openai.py art/axar-runes-portrait.md -v

# OpenAI API key — get one at https://platform.openai.com/api-keys
# Your org must be verified to call gpt-image-1.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Foundry VTT API credentials (for foundry-import tool)
# Get API key at https://forgevtt.com/account/api-keys
# World ID is visible in your world settings
FOUNDRY_API_KEY=your_foundry_api_key_here
FOUNDRY_WORLD_ID=your_foundry_world_id_here
