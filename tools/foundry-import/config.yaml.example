# Foundry VTT Import Configuration Template
# Copy to config.yaml and fill in your values, or use environment variables

foundry:
  # Base URL of your Foundry instance
  url: "https://forgevtt.com"

  # API key from https://forgevtt.com/account/api-keys
  api_key: "${FOUNDRY_API_KEY}"

  # World ID (found in world settings)
  world_id: "${FOUNDRY_WORLD_ID}"

  # Request timeout in seconds
  timeout: 30

  # Retry configuration
  max_retries: 3

campaign:
  # Root directory of campaign (relative to script directory)
  input_dir: "../../"

  # Output directory for JSON files
  output_dir: "json-export"

import:
  # Skip duplicates (don't re-import existing actors/journals)
  skip_duplicates: true

  # Rate limit between API calls (seconds)
  rate_limit: 0.1

  # Dry-run mode (preview without sending)
  dry_run: false

# Asset Configuration
assets:
  # Upload token images from art/finale/output/
  upload_tokens: false

  # Upload battlemap images for scenes
  upload_maps: false

  # Base path for asset uploads (relative to campaign root)
  art_directory: "art/finale/output"
